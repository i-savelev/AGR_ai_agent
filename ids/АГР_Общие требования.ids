            <ids:simpleValue>RusSet_Common</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>RUS_MSSK_SpaceAndZone_Name</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property dataType="IFCREAL" cardinality="required" instructions="Площадь">
          <ids:propertySet>
            <ids:simpleValue>RusSet_Quantities</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>RUS_Area</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property dataType="IFCTEXT" cardinality="required" instructions="Номер объекта (корпуса)">
          <ids:propertySet>
            <ids:simpleValue>RusSet_Location</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>RUS_Object</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property dataType="IFCTEXT" cardinality="required" instructions="Номер подобъекта (секции)">
          <ids:propertySet>
            <ids:simpleValue>RusSet_Location</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>RUS_Object_Sub</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property dataType="IFCTEXT" cardinality="required" instructions="Категория функциональной зоны">
          <ids:propertySet>
            <ids:simpleValue>RusSet_Identification</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>RUS_Zone</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property dataType="IFCTEXT" cardinality="required" instructions="Группа помещений">
          <ids:propertySet>
            <ids:simpleValue>RusSet_Identification</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>RUS_Group_Type</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property dataType="IFCTEXT" cardinality="required" instructions="Номер группы помещений">
          <ids:propertySet>
            <ids:simpleValue>RusSet_Identification</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>RUS_Group_Number</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property dataType="IFCTEXT" cardinality="required" instructions="Номер помещения">
          <ids:propertySet>
            <ids:simpleValue>RusSet_Identification</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>RUS_Number</ids:simpleValue>
