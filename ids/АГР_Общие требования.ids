    <ids:specification ifcVersion="IFC4" name="Помещение&#xA;Класс IFC: IfcSpace">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCSPACE</ids:simpleValue>
          </ids:name>
        </ids:entity>
        <ids:property dataType="IFCBOOLEAN">
          <ids:propertySet>
            <ids:simpleValue>RusSet_AGR</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>RUS_StudioApart</ids:simpleValue>
          </ids:baseName>
        </ids:property>
      </ids:applicability>
      <ids:requirements>
        <ids:property dataType="IFCTEXT" cardinality="required" instructions="Код помещения и зоны&#xA;МССК&#xA;">
